rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function platformAdminDoc() {
      return firestore.get(/databases/(default)/documents/platformAdmins/$(request.auth.uid));
    }

    function isPlatformAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/platformAdmins/$(request.auth.uid))
        && platformAdminDoc().data.role == 'super_admin';
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userDocStoreId() {
      return hasUserDoc() && userDoc().data.storeId != null
        ? userDoc().data.storeId
        : null;
    }

    function userDocRole() {
      return hasUserDoc() && userDoc().data.role != null
        ? userDoc().data.role
        : null;
    }

    function storeMemberDoc(storeId) {
      return firestore.get(/databases/(default)/documents/stores/$(storeId)/members/$(request.auth.uid));
    }

    function hasStoreMemberDoc(storeId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/stores/$(storeId)/members/$(request.auth.uid));
    }

    function storeMemberRole(storeId) {
      return hasStoreMemberDoc(storeId) && storeMemberDoc(storeId).data.role != null
        ? storeMemberDoc(storeId).data.role
        : null;
    }

    function isStaffRole(role) {
      return role == 'owner'
        || role == 'admin'
        || role == 'manager'
        || role == 'staff';
    }

    function isManagerRole(role) {
      return role == 'owner'
        || role == 'admin'
        || role == 'manager';
    }

    function isStoreStaff(storeId) {
      return signedIn()
        && (
          (
            userDocStoreId() == storeId
            && isStaffRole(userDocRole())
          )
          || (
            hasStoreMemberDoc(storeId)
            && isStaffRole(storeMemberRole(storeId))
          )
        );
    }

    function isStoreManager(storeId) {
      return signedIn()
        && (
          (
            userDocStoreId() == storeId
            && isManagerRole(userDocRole())
          )
          || (
            hasStoreMemberDoc(storeId)
            && isManagerRole(storeMemberRole(storeId))
          )
        );
    }

    match /stores/{storeId}/importJobs/{jobId}/{fileName=**} {
      allow read: if isPlatformAdmin() || isStoreStaff(storeId);
      allow write: if (isPlatformAdmin() || isStoreManager(storeId))
        && request.resource.size < 50 * 1024 * 1024
        && (
          request.resource.contentType.matches('text/.*')
          || request.resource.contentType == 'application/vnd.ms-excel'
          || request.resource.contentType == 'application/csv'
          || request.resource.contentType == 'text/csv'
          || request.resource.contentType == 'application/octet-stream'
        );
    }
  }
}
