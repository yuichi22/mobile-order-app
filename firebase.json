{
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "target": "app",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/createPrepayOrder",
        "function": {
          "functionId": "createPrepayOrder",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/createPostpayOrder",
        "function": {
          "functionId": "createPostpayOrder",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/issuePostpayReceipt",
        "function": {
          "functionId": "issuePostpayReceipt",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/preflightCustomerEntry",
        "function": {
          "functionId": "preflightCustomerEntry",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/preflightJoinCustomerSession",
        "function": {
          "functionId": "preflightJoinCustomerSession",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/preflightCustomerSession",
        "function": {
          "functionId": "preflightCustomerSession",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/bootstrapCustomerSession",
        "function": {
          "functionId": "bootstrapCustomerSession",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/joinCustomerSession",
        "function": {
          "functionId": "joinCustomerSession",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/restoreCustomerSessionMember",
        "function": {
          "functionId": "restoreCustomerSessionMember",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/ensureSessionInvite",
        "function": {
          "functionId": "ensureSessionInvite",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/requestPlatformAdminAccessCode",
        "function": {
          "functionId": "requestPlatformAdminAccessCode",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/verifyPlatformAdminAccessCode",
        "function": {
          "functionId": "verifyPlatformAdminAccessCode",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/verifyPlatformAdminSession",
        "function": {
          "functionId": "verifyPlatformAdminSession",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/requestPasswordResetMail",
        "function": {
          "functionId": "requestPasswordResetMail",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/requestEmailVerificationMail",
        "function": {
          "functionId": "requestEmailVerificationMail",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/createOwnerAccount",
        "function": {
          "functionId": "createOwnerAccount",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/createInvitedMember",
        "function": {
          "functionId": "createInvitedMember",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "/api/deleteStoreMember",
        "function": {
          "functionId": "deleteStoreMember",
          "region": "asia-northeast1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
