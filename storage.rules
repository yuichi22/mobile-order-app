rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isProductCsvImportUpload(storeId, jobId) {
      return request.resource.metadata.type == 'productCsvImport'
        && request.resource.metadata.storeId == storeId
        && request.resource.metadata.jobId == jobId
        && request.resource.metadata.createdByUid == request.auth.uid;
    }

    function isProductCsvImportFile(resourceData, storeId, jobId) {
      return resourceData.metadata.type == 'productCsvImport'
        && resourceData.metadata.storeId == storeId
        && resourceData.metadata.jobId == jobId
        && resourceData.metadata.createdByUid == request.auth.uid;
    }

    match /stores/{storeId}/importJobs/{jobId}/{fileName=**} {
      allow read: if signedIn()
        && isProductCsvImportFile(resource, storeId, jobId);

      allow write: if signedIn()
        && isProductCsvImportUpload(storeId, jobId)
        && request.resource.size < 50 * 1024 * 1024;
    }
  }
}
